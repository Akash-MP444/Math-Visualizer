```gitignore
# Dependencies
node_modules/

# Next.js
.next/
out/

# Production
dist/
build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment Variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Coverage
coverage/

# Testing
.vitest/

# TypeScript
*.tsbuildinfo

# IDE
.vscode/
.idea/

# OS Files
.DS_Store
Thumbs.db

# Temporary Files
tmp/
temp/

# Vercel
.vercel/

# Cache
.cache/

# Generated screenshots/videos (optional)
recordings/
exports/

# Python (if ever used)
__pycache__/
*.pyc
```
